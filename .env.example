# ---------------------------------------------------------------------------
# CGE-Agent example environment file.
# Copy this file to `.env` and fill in your own values:  cp .env.example .env
# `.env` is git-ignored and will never be committed.
# ---------------------------------------------------------------------------

# --- LLM endpoint used by the optimizer and executor (OpenAI-compatible) -----
# The entry point (examples/benchmark_and_evaluation.py) and all baseline
# scripts read these two variables. OPENAI_BASE_URL may point at the official
# OpenAI API or ANY OpenAI-compatible gateway that serves the configured model.
# The paper results were produced with model `gemini-2.5-flash-lite` served
# through an OpenAI-compatible gateway; set the base url accordingly.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Optional alternative backends (only needed if you switch build_*_llm) ---
# Aliyun DashScope (Qwen models)
ALIYUN_API_KEY=
DASHSCOPE_API_KEY=
# OpenRouter
OPENROUTER_API_KEY=

# --- Run-time switches (all optional, sensible defaults exist) ---------------
# Set to 1 to skip optimization and evaluate the saved best workflow directly.
USE_BEST_WORKFLOW=0
# Worker count for the (longer) held-out test evaluation.
TEST_EVAL_NUM_WORKERS=8
# Adaptive-evaluation success F1 threshold (only used when adaptive eval is on).
ADAPTIVE_SUCCESS_F1_THRESHOLD=0.3
